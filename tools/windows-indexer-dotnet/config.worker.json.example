{
  "serverUrl": "https://sls-planning.omnic.pro",
  "syncEndpoint": "/api/file-index/sync",
  "syncDeltaEndpoint": "/api/file-index/sync-delta",
  "clearEndpoint": "/api/file-index/clear",
  "scanRoot": ".",
  "scanIntervalSeconds": 30,
  "machineId": "PC-REMOTE-01",
  "maxPayloadBytes": 800000,
  "chunkMetadataOverheadBytes": 512,
  "requestTimeoutSeconds": 30,
  "retryCount": 3,
  "retryDelaySeconds": 3,
  "enableDeltaSync": true,
  "emitCycleLogs": true,
  "stateDbFileName": ".indexer-state.db",
  "includeExtensions": [".pdf", ".dxf"],
  "enablePreviewGateway": true,
  "previewGatewayPrefix": "http://+:5001/",
  "previewAllowedRoots": ["C:/PilotGroup"],
  "previewAllowedOrigin": "https://sls-planning.omnic.pro",
  "previewApiKey": "<preview_key>",
  "auth": {
    "apiKeyHeader": "X-API-Key",
    "apiKey": "<your_key>"
  }
}
